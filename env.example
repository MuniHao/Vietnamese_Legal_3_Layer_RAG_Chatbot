# Law Chat Application
# Environment variables

# Database
DATABASE_URL=postgresql://username@localhost:5432/phapdien_db

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Local LLM settings
LOCAL_LLM_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama3.2:3b

# Application settings
APP_NAME="Law Chat Assistant"
APP_VERSION="1.0.0"
DEBUG=True
HOST=0.0.0.0
PORT=8000

# Embedding settings - Using BAAI/bge-m3 for better Vietnamese support
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024

# Reduced for better semantic chunking
MAX_CHUNK_SIZE=500
CHUNK_OVERLAP=100

# Reduce chunk size when processing large documents to avoid high memory usage
# MAX_CHUNK_SIZE=200
# CHUNK_OVERLAP=40

# Reranker settings
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
USE_RERANKER=True
RERANK_TOP_K=8
FINAL_TOP_K=5

# RAG settings
SIMILARITY_THRESHOLD=0.35
TOP_K_RETRIEVAL=8

# Hybrid Retrieval settings (BM25 + Vector Search)
USE_HYBRID_RETRIEVE=True
BM25_WEIGHT=0.3
VECTOR_WEIGHT=0.7
HYBRID_ALPHA=0.5

# Summary-based Memory settings
USE_SUMMARY_MEMORY=True
SUMMARY_MODEL=qwen2.5:1.5b
MAX_MESSAGES_BEFORE_SUMMARY=10
SUMMARY_THRESHOLD=8

# Topic History settings
USE_TOPIC_HISTORY=True
TOPIC_MODEL=qwen2.5:1.5b
MAX_TOPICS_PER_CONVERSATION=5